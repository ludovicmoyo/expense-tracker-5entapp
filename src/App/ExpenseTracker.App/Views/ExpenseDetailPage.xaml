<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ExpenseTracker.App.ViewModels"
             x:Class="ExpenseTracker.App.Views.ExpenseDetailPage"
             x:DataType="vm:ExpenseDetailViewModel"
             Title="Expense">

  <ScrollView>
    <VerticalStackLayout Padding="20" Spacing="14" MaximumWidthRequest="640" HorizontalOptions="Center">

      <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

      <Border Style="{StaticResource CardFrame}" IsVisible="{Binding Expense, Converter={StaticResource NotNullConverter}}">
        <VerticalStackLayout Spacing="10">

          <Label Text="{Binding Expense.Description}"
                 FontSize="20" FontAttributes="Bold" />

          <HorizontalStackLayout Spacing="8">
            <Border Style="{StaticResource StatusBadge}"
                    BackgroundColor="{Binding Expense.Status, Converter={StaticResource StatusToColorConverter}}">
              <Label Style="{StaticResource StatusBadgeText}" Text="{Binding Expense.Status}" />
            </Border>
            <Border Style="{StaticResource StatusBadge}"
                    BackgroundColor="{StaticResource Accent}"
                    IsVisible="{Binding Expense.RequiresSeniorApproval}">
              <Label Style="{StaticResource StatusBadgeText}" Text="Senior approval" />
            </Border>
          </HorizontalStackLayout>

          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
            <Label Grid.Row="0" Grid.Column="0" Text="Amount" FontAttributes="Bold" />
            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Expense.Amount, StringFormat='{0:0.00} €'}" />

            <Label Grid.Row="1" Grid.Column="0" Text="Category" FontAttributes="Bold" />
            <Label Grid.Row="1" Grid.Column="1" Text="{Binding Expense.Category}" />

            <Label Grid.Row="2" Grid.Column="0" Text="Created" FontAttributes="Bold" />
            <Label Grid.Row="2" Grid.Column="1" Text="{Binding Expense.CreatedAt, StringFormat='{0:dd MMM yyyy, HH:mm}'}" />

            <Label Grid.Row="3" Grid.Column="0" Text="Updated" FontAttributes="Bold" />
            <Label Grid.Row="3" Grid.Column="1" Text="{Binding Expense.UpdatedAt, StringFormat='{0:dd MMM yyyy, HH:mm}'}" />
          </Grid>

          <BoxView HeightRequest="1" Color="{StaticResource Border}" />

          <Label Text="Rejection comment" FontAttributes="Bold"
                 IsVisible="{Binding Expense.DecisionComment, Converter={StaticResource StringNotEmptyConverter}}" />
          <Label Text="{Binding Expense.DecisionComment}"
                 TextColor="{StaticResource Danger}"
                 IsVisible="{Binding Expense.DecisionComment, Converter={StaticResource StringNotEmptyConverter}}" />
        </VerticalStackLayout>
      </Border>

      <!-- Receipt section -->
      <Border Style="{StaticResource CardFrame}">
        <VerticalStackLayout Spacing="10">
          <Label Text="Receipt" FontAttributes="Bold" FontSize="16" />

          <Image Source="{Binding ReceiptUrl}"
                 Aspect="AspectFit"
                 MaximumHeightRequest="320"
                 IsVisible="{Binding ReceiptUrl, Converter={StaticResource StringNotEmptyConverter}}" />

          <Label Text="No receipt attached."
                 Opacity="0.7"
                 IsVisible="{Binding ReceiptUrl, Converter={StaticResource StringEmptyConverter}}" />

          <Button Text="Attach / Replace receipt"
                  Style="{StaticResource SecondaryButton}"
                  Command="{Binding PickReceiptCommand}"
                  IsVisible="{Binding CanEditReceipt}" />
        </VerticalStackLayout>
      </Border>

      <!-- Actions -->
      <Button Text="Submit for approval"
              Command="{Binding SubmitCommand}"
              IsVisible="{Binding CanSubmit}"
              IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />

      <Button Text="Resubmit"
              Style="{StaticResource SuccessButton}"
              Command="{Binding SubmitCommand}"
              IsVisible="{Binding CanResubmit}"
              IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />

      <Label Text="{Binding ErrorMessage}"
             TextColor="{StaticResource Danger}"
             IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
