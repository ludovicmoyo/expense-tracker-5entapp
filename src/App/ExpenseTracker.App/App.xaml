<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:ExpenseTracker.App.Converters"
             x:Class="ExpenseTracker.App.App">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
        <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <conv:InvertedBoolConverter x:Key="InvertedBoolConverter" />
      <conv:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
      <conv:StringEmptyConverter x:Key="StringEmptyConverter" />
      <conv:NotNullConverter x:Key="NotNullConverter" />
      <conv:StatusToColorConverter x:Key="StatusToColorConverter" />
      <conv:AmountConverter x:Key="AmountConverter" />
    </ResourceDictionary>
  </Application.Resources>
</Application>
