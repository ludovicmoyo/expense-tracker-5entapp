<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

  <Style TargetType="Page" ApplyToDerivedTypes="True">
    <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
  </Style>

  <Style TargetType="Entry">
    <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    <Setter Property="PlaceholderColor" Value="{StaticResource OnSurfaceMuted}" />
    <Setter Property="BackgroundColor" Value="{StaticResource SurfaceMuted}" />
    <Setter Property="HeightRequest" Value="44" />
  </Style>

  <Style TargetType="Editor">
    <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    <Setter Property="PlaceholderColor" Value="{StaticResource OnSurfaceMuted}" />
    <Setter Property="BackgroundColor" Value="{StaticResource SurfaceMuted}" />
  </Style>

  <Style TargetType="Button">
    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
    <Setter Property="TextColor" Value="White" />
    <Setter Property="FontAttributes" Value="Bold" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="HeightRequest" Value="44" />
  </Style>

  <Style x:Key="DangerButton" TargetType="Button">
    <Setter Property="BackgroundColor" Value="{StaticResource Danger}" />
    <Setter Property="TextColor" Value="White" />
    <Setter Property="FontAttributes" Value="Bold" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="HeightRequest" Value="44" />
  </Style>

  <Style x:Key="SuccessButton" TargetType="Button">
    <Setter Property="BackgroundColor" Value="{StaticResource Success}" />
    <Setter Property="TextColor" Value="White" />
    <Setter Property="FontAttributes" Value="Bold" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="HeightRequest" Value="44" />
  </Style>

  <Style x:Key="SecondaryButton" TargetType="Button">
    <Setter Property="BackgroundColor" Value="{StaticResource SurfaceMuted}" />
    <Setter Property="TextColor" Value="{StaticResource OnSurface}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="HeightRequest" Value="44" />
  </Style>

  <Style x:Key="CardFrame" TargetType="Border">
    <Setter Property="Padding" Value="16" />
    <Setter Property="StrokeShape" Value="RoundRectangle 12" />
    <Setter Property="StrokeThickness" Value="1" />
    <Setter Property="Stroke" Value="{StaticResource Border}" />
    <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
  </Style>

  <Style x:Key="StatusBadge" TargetType="Border">
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="StrokeShape" Value="RoundRectangle 999" />
    <Setter Property="StrokeThickness" Value="0" />
    <Setter Property="HorizontalOptions" Value="Start" />
  </Style>

  <Style x:Key="StatusBadgeText" TargetType="Label">
    <Setter Property="TextColor" Value="White" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontAttributes" Value="Bold" />
  </Style>

</ResourceDictionary>
