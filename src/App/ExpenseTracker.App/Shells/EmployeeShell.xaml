<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:ExpenseTracker.App.Views"
       x:Class="ExpenseTracker.App.Shells.EmployeeShell"
       FlyoutBehavior="Disabled"
       Shell.TabBarBackgroundColor="{StaticResource Surface}">

  <TabBar>
    <ShellContent Title="My Expenses"
                  Icon="{x:Null}"
                  ContentTemplate="{DataTemplate views:MyExpensesPage}"
                  Route="myexpenses" />
  </TabBar>

</Shell>
